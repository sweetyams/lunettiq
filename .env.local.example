# Shopify Storefront API
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-access-token

# Shopify Customer Account API (OAuth)
SHOPIFY_CUSTOMER_ACCOUNT_API_CLIENT_ID=your-customer-account-client-id
SHOPIFY_CUSTOMER_ACCOUNT_API_CLIENT_SECRET=your-customer-account-client-secret

# App URL (for OAuth redirect)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ISR Revalidation webhook secret
REVALIDATION_SECRET=your-revalidation-secret
