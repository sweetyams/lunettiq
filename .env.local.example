# ─── Shopify Storefront API ────────────────────────────────
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-access-token

# ─── Shopify Customer Account API (OAuth) ─────────────────
SHOPIFY_CUSTOMER_ACCOUNT_API_CLIENT_ID=your-customer-account-client-id
SHOPIFY_CUSTOMER_ACCOUNT_API_CLIENT_SECRET=your-customer-account-client-secret

# ─── Shopify Admin API (for CRM write-through) ────────────
SHOPIFY_ADMIN_API_ACCESS_TOKEN=your-admin-api-access-token
SHOPIFY_WEBHOOK_SECRET=your-webhook-hmac-secret

# ─── App URL ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── ISR Revalidation ────────────────────────────────────
REVALIDATION_SECRET=your-revalidation-secret

# ─── Neon Postgres ────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/lunettiq?sslmode=require

# ─── Clerk (Staff Auth) ──────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# ─── Inngest ─────────────────────────────────────────────
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# ─── Upstash Redis ───────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Anthropic (AI Segmentation)
ANTHROPIC_API_KEY=

# ─── Safety: External Communications ──────────────────────
# Set to "true" to block ALL outbound emails/SMS (Klaviyo) even in production
DISABLE_EXTERNAL_COMMS=true
# Comma-separated list of emails allowed to receive comms in staging/testing
# Leave empty to block all. Only used when DISABLE_EXTERNAL_COMMS is not "true".
ALLOWED_TEST_EMAILS=

# ─── Square POS (READ-ONLY) ──────────────────────────────
# Integration reads Square data only. NO writes to Square.
SQUARE_APPLICATION_ID=
SQUARE_ACCESS_TOKEN=
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_ENVIRONMENT=sandbox  # sandbox | production
